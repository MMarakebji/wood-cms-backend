generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model Admin {
  id           String    @id @default(uuid()) @db.Uuid
  email        String    @unique @db.VarChar(255)
  passwordHash String    @map("password_hash") @db.Text
  fullName     String    @map("full_name") @db.VarChar(120)
  isActive     Boolean   @default(true) @map("is_active")
  lastLoginAt  DateTime? @map("last_login_at") @db.Timestamptz(6)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  refreshSessions RefreshSession[]

  @@map("admins")
}

model RefreshSession {
  id        String    @id @default(uuid()) @db.Uuid
  adminId   String    @map("admin_id") @db.Uuid
  tokenHash String    @unique @map("token_hash") @db.Text
  userAgent String?   @map("user_agent") @db.Text
  ipAddress String?   @map("ip_address") @db.Inet
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(6)
  revokedAt DateTime? @map("revoked_at") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  admin Admin @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@map("refresh_sessions")
}

model HomepageSetting {
  id                Int      @id @default(1) @db.SmallInt
  companyName       String   @map("company_name") @db.VarChar(150)
  logoUrl           String   @map("logo_url") @db.Text
  logoPublicId      String   @map("logo_public_id") @db.Text
  logoAltText       String   @map("logo_alt_text") @db.VarChar(255)
  phone             String   @db.VarChar(40)
  email             String?  @db.VarChar(255)
  addressLine1      String   @map("address_line_1") @db.VarChar(255)
  addressLine2      String?  @map("address_line_2") @db.VarChar(255)
  privacyPolicyText String?  @map("privacy_policy_text") @db.VarChar(100)
  privacyPolicyUrl  String?  @map("privacy_policy_url") @db.Text
  footerText        String?  @map("footer_text") @db.Text
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("homepage_settings")
}

model HomepageSection {
  id                      String   @id @default(uuid()) @db.Uuid
  sectionKey              String   @unique @map("section_key") @db.VarChar(80)
  sectionType             String   @map("section_type") @db.VarChar(40)
  title                   String?  @db.VarChar(255)
  subtitle                String?  @db.VarChar(255)
  body                    String?  @db.Text
  buttonText              String?  @map("button_text") @db.VarChar(100)
  buttonLink              String?  @map("button_link") @db.VarChar(255)
  backgroundImageUrl      String?  @map("background_image_url") @db.Text
  backgroundImagePublicId String?  @map("background_image_public_id") @db.Text
  backgroundImageAltText  String?  @map("background_image_alt_text") @db.VarChar(255)
  displayOrder            Int      @map("display_order")
  isActive                Boolean  @default(true) @map("is_active")
  createdAt               DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt               DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  images HomepageSectionImage[]
  items  HomepageSectionItem[]

  @@index([isActive, displayOrder])
  @@map("homepage_sections")
}

model HomepageSectionImage {
  id            String   @id @default(uuid()) @db.Uuid
  sectionId     String   @map("section_id") @db.Uuid
  imageUrl      String   @map("image_url") @db.Text
  imagePublicId String   @map("image_public_id") @db.Text
  altText       String   @map("alt_text") @db.VarChar(255)
  caption       String?  @db.VarChar(255)
  displayOrder  Int      @map("display_order")
  isPrimary     Boolean  @default(false) @map("is_primary")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  section HomepageSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@index([sectionId])
  @@map("homepage_section_images")
}

model HomepageSectionItem {
  id           String   @id @default(uuid()) @db.Uuid
  sectionId    String   @map("section_id") @db.Uuid
  title        String?  @db.VarChar(180)
  description  String   @db.Text
  iconName     String?  @map("icon_name") @db.VarChar(80)
  displayOrder Int      @map("display_order")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  section HomepageSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@index([sectionId])
  @@map("homepage_section_items")
}

model Banner {
  id            String   @id @default(uuid()) @db.Uuid
  title         String   @db.VarChar(255)
  subtitle      String?  @db.VarChar(255)
  description   String?  @db.Text
  buttonText    String?  @map("button_text") @db.VarChar(100)
  buttonLink    String?  @map("button_link") @db.VarChar(255)
  imageUrl      String   @map("image_url") @db.Text
  imagePublicId String   @map("image_public_id") @db.Text
  imageAltText  String   @map("image_alt_text") @db.VarChar(255)
  displayOrder  Int      @map("display_order")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([isActive, displayOrder])
  @@map("banners")
}

model Service {
  id               String   @id @default(uuid()) @db.Uuid
  name             String   @db.VarChar(160)
  slug             String   @unique @db.VarChar(180)
  shortDescription String?  @map("short_description") @db.VarChar(500)
  description      String?  @db.Text
  imageUrl         String?  @map("image_url") @db.Text
  imagePublicId    String?  @map("image_public_id") @db.Text
  imageAltText     String?  @map("image_alt_text") @db.VarChar(255)
  displayOrder     Int      @map("display_order")
  isActive         Boolean  @default(true) @map("is_active")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([isActive, displayOrder])
  @@map("services")
}

model Product {
  id               String   @id @default(uuid()) @db.Uuid
  name             String   @db.VarChar(160)
  slug             String   @unique @db.VarChar(180)
  shortDescription String?  @map("short_description") @db.VarChar(500)
  description      String?  @db.Text
  basePrice        Decimal? @map("base_price") @db.Decimal(12, 2)
  currency         String   @default("CZK") @db.Char(3)
  priceUnit        String?  @map("price_unit") @db.VarChar(40)
  displayOrder     Int      @map("display_order")
  isActive         Boolean  @default(true) @map("is_active")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  features   ProductFeature[]
  images     ProductImage[]
  priceLists PriceList[]

  @@index([isActive, displayOrder])
  @@map("products")
}

model ProductFeature {
  id           String   @id @default(uuid()) @db.Uuid
  productId    String   @map("product_id") @db.Uuid
  label        String   @db.VarChar(255)
  featureType  String   @map("feature_type") @db.VarChar(20)
  displayOrder Int      @map("display_order")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_features")
}

model ProductImage {
  id            String   @id @default(uuid()) @db.Uuid
  productId     String   @map("product_id") @db.Uuid
  imageUrl      String   @map("image_url") @db.Text
  imagePublicId String   @map("image_public_id") @db.Text
  altText       String   @map("alt_text") @db.VarChar(255)
  sortOrder     Int      @map("sort_order")
  isPrimary     Boolean  @default(false) @map("is_primary")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, sortOrder])
  @@index([productId])
  @@map("product_images")
}

model PriceList {
  id            String   @id @default(uuid()) @db.Uuid
  productId     String?  @map("product_id") @db.Uuid
  listName      String   @map("list_name") @db.VarChar(160)
  itemName      String?  @map("item_name") @db.VarChar(160)
  lengthMm      Int?     @map("length_mm")
  widthMm       Int?     @map("width_mm")
  thicknessMm   Int?     @map("thickness_mm")
  volumeM3      Decimal? @map("volume_m3") @db.Decimal(10, 4)
  pricePerM3    Decimal? @map("price_per_m3") @db.Decimal(12, 2)
  pricePerPiece Decimal? @map("price_per_piece") @db.Decimal(12, 2)
  currency      String   @default("CZK") @db.Char(3)
  displayOrder  Int      @map("display_order")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([productId])
  @@index([isActive, displayOrder])
  @@map("price_lists")
}

model ContactMessage {
  id        String    @id @default(uuid()) @db.Uuid
  name      String    @db.VarChar(150)
  phone     String    @db.VarChar(40)
  email     String?   @db.VarChar(255)
  message   String    @db.Text
  status    String    @default("NEW") @db.VarChar(20)
  readAt    DateTime? @map("read_at") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([status, createdAt])
  @@map("contact_messages")
}
